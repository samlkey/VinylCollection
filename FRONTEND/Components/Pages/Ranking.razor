@page "/ranking"
@rendermode InteractiveServer
@using FRONTEND.Services
@using FRONTEND.Data
@using FRONTEND.Components.Shared

@inject IVinylService VinylService
@inject IColorAnalysisService ColorService
@inject ICurrentAlbumColorService CurrentAlbumColorService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Ranking</PageTitle>

@{
    var currentAlbum = rankedAlbums[currentAlbumIndex];
    CurrentAlbumColorService.CurrentAlbumColor = currentAlbum.PrimaryColour ?? "#000000";
    var rankPos = currentAlbumIndex + 1;
    var medalClass = rankPos == 1 ? "medal-gold" : rankPos == 2 ? "medal-silver" : rankPos == 3 ? "medal-bronze" : "";
}

<div class="rank-scene"
     style="--album-bg:@(currentAlbum.PrimaryColour ?? "#1a1a1a");"
     @ref="_keyTarget"
     @onkeydown="HandleKeyDown"
     @onwheel="HandleWheel"
     tabindex="0">

    <!-- Full-bleed blurred background -->
    <div class="rank-bg" style="background-image: url('@currentAlbum.ImgSrc')"></div>
    <div class="rank-bg-overlay"></div>

    <Search IsBackVisible="false" />

    @if (rankedAlbums != null && rankedAlbums.Count > 0)
    {
        <!-- Hero: art (with numeral inside) + info -->
        <div class="rank-hero" @key="currentAlbumIndex">

            <!-- Album art + ghost rank numeral (behind art) -->
            <div class="rank-art-col">
                <span class="rank-numeral @medalClass">@(rankPos.ToString("D2"))</span>
                <img src="@currentAlbum.ImgSrc"
                     alt="@currentAlbum.Name"
                     class="rank-art"
                     @onclick="() => NavigateToAlbum(currentAlbum.Name!)"
                     draggable="false" />
            </div>

            <!-- Info panel -->
            <div class="rank-info-col">
                <p class="rank-label">No. @rankPos</p>
                <h2 class="rank-album-name" @onclick="() => NavigateToAlbum(currentAlbum.Name!)">@currentAlbum.Name</h2>
                <p class="rank-artist">@currentAlbum.Artist</p>
                <div class="rank-rating">
                    <Rating Value="@currentAlbum.Rating" TextColor="color: white"></Rating>
                </div>
            </div>
        </div>

        <!-- Bottom navigation -->
        <nav class="rank-nav">
            <button class="rank-nav-btn" @onclick="PreviousAlbum" disabled="@(currentAlbumIndex <= 0)">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
                </svg>
                Prev
            </button>

            <span class="rank-counter">
                @rankPos <span class="rank-sep">/</span> @rankedAlbums.Count
            </span>

            <button class="rank-nav-btn" @onclick="NextAlbum" disabled="@(currentAlbumIndex >= rankedAlbums.Count - 1)">
                Next
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="transform:scaleX(-1)">
                    <path d="M15.41 7.41L14 6l-6 6 6 6 1.41-1.41L10.83 12z"/>
                </svg>
            </button>
        </nav>
    }
</div>

@code {
    private List<Album> albums = new List<Album>();
    private List<Album> rankedAlbums = new List<Album>();
    private int currentAlbumIndex = 0;
    private ElementReference _keyTarget;

    protected override async Task OnInitializedAsync() {
        albums = await VinylService.GetAllAlbumsAsync();
        rankedAlbums = GetAlbumsByRating();

        if (rankedAlbums.Count > 0)
        {
            currentAlbumIndex = rankedAlbums.Count - 1;
        }

        foreach (var album in rankedAlbums)
        {
            if (string.IsNullOrEmpty(album.PrimaryColour))
            {
                await album.CalculatePrimaryColourAsync(ColorService);
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("carouselGestures.init", _keyTarget, DotNetObjectReference.Create(this));
        }
    }

    private List<Album> GetAlbumsByRating() => albums.OrderByDescending(a => a.Rating).ToList();

    private void NavigateToAlbum(string albumName)
    {
        Navigation.NavigateTo($"/album/{albumName.ToLower().Replace(" ", "_")}");
    }

    [JSInvokable]
    public void NextAlbum()
    {
        if (rankedAlbums.Count > 0 && currentAlbumIndex < rankedAlbums.Count - 1)
        {
            currentAlbumIndex++;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public void PreviousAlbum()
    {
        if (rankedAlbums.Count > 0 && currentAlbumIndex > 0)
        {
            currentAlbumIndex--;
            StateHasChanged();
        }
    }

    private void SetAlbumIndex(int index)
    {
        if (index >= 0 && index < rankedAlbums.Count)
        {
            currentAlbumIndex = index;
        }
    }

    private int GetPreviousIndex()
    {
        if (rankedAlbums.Count == 0) return 0;
        if (currentAlbumIndex <= 0) return 0;
        return currentAlbumIndex - 1;
    }

    private int GetNextIndex()
    {
        if (rankedAlbums.Count == 0) return 0;
        if (currentAlbumIndex >= rankedAlbums.Count - 1) return rankedAlbums.Count - 1;
        return currentAlbumIndex + 1;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "ArrowRight" || e.Key == "scrollUp")
        {
            NextAlbum();
            await InvokeAsync(StateHasChanged);
        }
        else if (e.Key == "ArrowLeft" || e.Key == "scrollDown")
        {
            PreviousAlbum();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleWheel(WheelEventArgs e)
    {
        if (e.DeltaY > 0)
        {
            NextAlbum();
            await InvokeAsync(StateHasChanged);
        }
        else if (e.DeltaY < 0)
        {
            PreviousAlbum();
            await InvokeAsync(StateHasChanged);
        }
    }
}
